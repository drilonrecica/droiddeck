{
  "name": "droiddeck",
  "version": "0.1.2",
  "description": "A terminal dashboard and CLI command center for native Android development.",
  "license": "MIT",
  "author": "Drilon Recica",
  "homepage": "https://github.com/drilonrecica/droiddeck#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drilonrecica/droiddeck.git"
  },
  "bugs": {
    "url": "https://github.com/drilonrecica/droiddeck/issues"
  },
  "keywords": [
    "android",
    "adb",
    "gradle",
    "cli",
    "tui",
    "logcat"
  ],
  "type": "module",
  "bin": {
    "droiddeck": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=20"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "pack:dry": "npm pack --dry-run",
    "start": "bun dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentui/core": "0.3.0",
    "@opentui/react": "0.3.0",
    "commander": "^12.1.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "open": "^11.0.0",
    "react": "19.2.6",
    "react-devtools-core": "7.0.1",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@types/react": "19.2.15",
    "typescript": "^5.7.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
