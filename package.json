{
  "name": "droiddeck",
  "version": "0.1.0",
  "description": "A terminal dashboard and CLI command center for native Android development.",
  "license": "MIT",
  "author": "Drilon Recica",
  "keywords": [
    "android",
    "adb",
    "gradle",
    "cli",
    "tui",
    "logcat"
  ],
  "type": "module",
  "bin": {
    "droiddeck": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "pack:dry": "npm pack --dry-run",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "ink": "5.2.1",
    "ink-select-input": "6.2.0",
    "ink-spinner": "5.0.0",
    "open": "^11.0.0",
    "react": "18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@types/react": "18.2.79",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
