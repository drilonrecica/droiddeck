{
  "name": "droiddeck",
  "version": "0.1.0",
  "description": "A terminal dashboard and CLI command center for native Android development.",
  "type": "module",
  "bin": {
    "droiddeck": "./dist/index.js"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "figures": "^6.1.0",
    "fs-extra": "^11.2.0",
    "ink": "^5.1.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "strip-ansi": "^7.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
